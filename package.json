{
	"name": "@mookielianhd/n8n-nodes-hetzner-cloud",
	"version": "0.1.0",
	"description": "n8n community node for the Hetzner Cloud API - manage servers, volumes, networks, firewalls, load balancers, floating/primary IPs, SSH keys, images and more",
	"license": "MIT",
	"homepage": "https://github.com/MookieLian/n8n-nodes-hetzner-cloud#readme",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"hetzner",
		"hetzner-cloud",
		"hcloud"
	],
	"author": {
		"name": "mookielianhd",
		"email": "mookielianhd@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/MookieLian/n8n-nodes-hetzner-cloud.git"
	},
	"bugs": {
		"url": "https://github.com/MookieLian/n8n-nodes-hetzner-cloud/issues"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/HetznerCloudApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/HetznerCloud/HetznerCloud.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.29.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
